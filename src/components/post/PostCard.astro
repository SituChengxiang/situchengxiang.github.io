---
import { render, type CollectionEntry } from 'astro:content'

interface Props {
  entry: CollectionEntry<'posts'>
  index: number
}

const { entry, index } = Astro.props

const { remarkPluginFrontmatter } = await render(entry)

let coverImage = entry.data.cover
if (!coverImage && entry.body) {
  const imgMatch = entry.body.match(/!\[.*?\]\(([^)]+)\)/)
  if (imgMatch) {
    coverImage = imgMatch[1]
  }
}

const placeholders = [
  '/images/placeholder-01.jpg',
  '/images/placeholder-02.jpg',
  '/images/placeholder-03.jpg',
  '/images/placeholder-04.png',
]
const displayImage = coverImage || placeholders[index % 4]

const d = entry.data.date
const dateStr = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
const words = remarkPluginFrontmatter.words
const minutes = Math.ceil(remarkPluginFrontmatter.readingMinutes)
---

<a
  class="fluent-card block relative rounded-xl overflow-hidden focus-visible:outline-0 focus-visible:ring-2 focus-visible:ring-accent/50 group h-full"
  href={`/posts/${entry.id}`}
  data-card
>
  <div class="reveal-base"></div>
  <div class="reveal-spot"></div>
  <div class="p-3 relative z-10">
    <div class="relative w-full h-40 rounded-lg overflow-hidden">
      <img
        class="w-full h-full object-cover select-none"
        src={displayImage}
        alt={entry.data.title}
        loading="lazy"
      />
    </div>
  </div>
  <div class="px-5 pb-5 flex flex-col flex-1 relative z-10">
    <div class="flex items-center gap-3 text-xs text-secondary">
      <time datetime={dateStr}>{dateStr}</time>
      <span>{words} 字</span>
      <span>{minutes} 分钟</span>
    </div>
    <h2 class="mt-3 text-lg font-bold line-clamp-2 leading-snug">
      {entry.data.title}
      {entry.data.sticky > 0 && (
        <i class="inline-block size-4 leading-none iconfont icon-pushpin text-red-500 ml-1 align-middle" />
      )}
    </h2>
    {entry.data.summary && (
      <p class="mt-2 text-sm text-secondary line-clamp-2 leading-relaxed flex-1">{entry.data.summary}</p>
    )}
    {entry.data.category && (
      <div class="mt-3 pt-3 border-t border-primary">
        <span class="text-xs text-accent">{entry.data.category}</span>
      </div>
    )}
  </div>
</a>
